{
  "name": "@umpledger/sdk",
  "version": "2.0.0-alpha.2",
  "description": "Universal Monetization Protocol SDK — The payment rail for the autonomous economy",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pricing": {
      "import": "./dist/pricing/index.mjs",
      "require": "./dist/pricing/index.js",
      "types": "./dist/pricing/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "monetization",
    "ai-agents",
    "billing",
    "pricing",
    "settlement",
    "agent-commerce",
    "protocol"
  ],
  "author": "UMPLedger",
  "license": "Apache-2.0",
  "homepage": "https://umpledger.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/umpledger/ump-protocol"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/uuid": "^9.0.8",
    "eslint": "^8.50.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0"
  }
}
