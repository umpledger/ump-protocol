# UMP Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://ump:ump_secret@localhost:5432/ump_db

# Redis (for metering queue & rate limiting)
REDIS_URL=redis://localhost:6379

# API Key Prefix (all valid keys start with this)
API_KEY_PREFIX=ump_sk_

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# Settlement
MAX_SETTLEMENT_BATCH_SIZE=1000
SETTLEMENT_TIMEOUT_MS=5000

# Logging
LOG_LEVEL=info
