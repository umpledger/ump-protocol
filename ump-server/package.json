{
  "name": "@umpledger/server",
  "version": "2.0.0-alpha.1",
  "description": "UMP v2.0 API Server — HTTP endpoints for the Universal Monetization Protocol",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "echo 'No compile step - using tsx at runtime'",
    "start": "tsx src/server.ts",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@umpledger/sdk": "^2.0.0-alpha.2",
    "fastify": "^4.25.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "uuid": "^9.0.0",
    "pg": "^8.12.0",
    "dotenv": "^16.3.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
