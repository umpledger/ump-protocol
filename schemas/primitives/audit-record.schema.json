{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ump.umpledger.com/schemas/v1/audit-record.schema.json",
  "title": "UMP Audit Record",
  "description": "Immutable record of all actions affecting monetization entities. Audit records provide comprehensive traceability, compliance documentation, and forensic capabilities for all system operations.",
  "type": "object",
  "required": [
    "audit_id",
    "timestamp",
    "operation_type",
    "actor",
    "target",
    "created_at"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique, immutable identifier for this audit record."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when operation occurred."
    },
    "operation_type": {
      "type": "string",
      "enum": [
        "CREATE",
        "READ",
        "UPDATE",
        "DELETE",
        "EXECUTE",
        "APPROVE",
        "REJECT",
        "CANCEL",
        "EXPORT",
        "IMPORT",
        "AUTHENTICATE",
        "AUTHORIZE",
        "PERMISSION_CHANGE",
        "DATA_ACCESS",
        "REPORT_GENERATION",
        "CUSTOM"
      ],
      "description": "Type of operation performed."
    },
    "operation_status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "FAILURE",
        "PARTIAL_SUCCESS",
        "REJECTED",
        "TIMEOUT",
        "UNKNOWN"
      ],
      "description": "Outcome of the operation."
    },
    "actor": {
      "type": "object",
      "required": [
        "actor_type"
      ],
      "description": "Entity performing the action.",
      "properties": {
        "actor_type": {
          "type": "string",
          "enum": [
            "HUMAN",
            "SERVICE_ACCOUNT",
            "SYSTEM",
            "API_CLIENT",
            "EXTERNAL_SYSTEM",
            "AGENT"
          ]
        },
        "actor_id": {
          "type": "string",
          "description": "Unique identifier of the actor."
        },
        "actor_name": {
          "type": "string",
          "description": "Display name of actor."
        },
        "user_id": {
          "type": "string",
          "description": "User ID if actor is human."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "ip_address": {
          "type": "string",
          "format": "ipv4",
          "description": "IP address from which action originated."
        },
        "user_agent": {
          "type": "string",
          "description": "Browser/client user agent string."
        },
        "session_id": {
          "type": "string",
          "description": "Session or request ID for tracing."
        },
        "organization_id": {
          "type": "string",
          "description": "Organization context of actor."
        },
        "roles": {
          "type": "array",
          "description": "Roles held by actor at time of action.",
          "items": {
            "type": "string",
            "examples": [
              "ADMIN",
              "FINANCE_MANAGER",
              "BILLING_OPERATOR",
              "AUDITOR",
              "API_USER"
            ]
          }
        },
        "permissions": {
          "type": "array",
          "description": "Specific permissions used.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "target": {
      "type": "object",
      "required": [
        "entity_type",
        "entity_id"
      ],
      "description": "Entity being acted upon.",
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": [
            "CONTRACT",
            "INVOICE",
            "USAGE_EVENT",
            "SETTLEMENT",
            "PRICING_RULE",
            "POLICY",
            "ACCOUNT",
            "ENTITY",
            "VALUE_UNIT",
            "DISCOUNT",
            "CREDIT_NOTE",
            "PAYMENT",
            "SLA",
            "OTHER"
          ]
        },
        "entity_id": {
          "type": "string",
          "description": "Unique identifier of target entity."
        },
        "entity_name": {
          "type": "string",
          "description": "Display name or description of entity."
        },
        "entity_status_before": {
          "type": "string",
          "description": "Entity status prior to operation."
        },
        "entity_status_after": {
          "type": "string",
          "description": "Entity status after operation."
        }
      }
    },
    "changes": {
      "type": "object",
      "description": "State changes resulting from the operation.",
      "properties": {
        "before_state": {
          "type": "object",
          "additionalProperties": true,
          "description": "Entity state before operation (or relevant fields)."
        },
        "after_state": {
          "type": "object",
          "additionalProperties": true,
          "description": "Entity state after operation (or relevant fields)."
        },
        "modified_fields": {
          "type": "array",
          "description": "Which fields were modified.",
          "items": {
            "type": "object",
            "properties": {
              "field_name": {
                "type": "string"
              },
              "old_value": {
                "description": "Previous value."
              },
              "new_value": {
                "description": "Updated value."
              },
              "change_type": {
                "type": "string",
                "enum": [
                  "ADDED",
                  "REMOVED",
                  "MODIFIED",
                  "UNCHANGED"
                ]
              }
            }
          }
        },
        "change_summary": {
          "type": "string",
          "description": "Human-readable summary of changes."
        }
      }
    },
    "request_details": {
      "type": "object",
      "description": "Details of the request triggering audit.",
      "properties": {
        "request_id": {
          "type": "string",
          "description": "Unique request identifier."
        },
        "request_method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE",
            "CLI",
            "UI",
            "BATCH",
            "WEBHOOK",
            "MANUAL"
          ]
        },
        "request_endpoint": {
          "type": "string",
          "description": "API endpoint or UI action."
        },
        "request_parameters": {
          "type": "object",
          "additionalProperties": true,
          "description": "Request parameters (sanitized of sensitive data)."
        },
        "response_status": {
          "type": "integer",
          "examples": [
            200,
            201,
            400,
            401,
            403,
            404,
            500
          ]
        },
        "response_time_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Processing time in milliseconds."
        }
      }
    },
    "policies_evaluated": {
      "type": "array",
      "description": "Policies checked during operation.",
      "items": {
        "type": "object",
        "properties": {
          "policy_id": {
            "type": "string"
          },
          "policy_name": {
            "type": "string"
          },
          "policy_type": {
            "type": "string"
          },
          "rules_evaluated": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rule_id": {
                  "type": "string"
                },
                "rule_name": {
                  "type": "string"
                },
                "matched": {
                  "type": "boolean"
                },
                "action_taken": {
                  "type": "string"
                }
              }
            }
          },
          "enforcement_result": {
            "type": "string",
            "enum": [
              "ALLOWED",
              "BLOCKED",
              "WARNED",
              "LOGGED"
            ]
          }
        }
      }
    },
    "approval_chain": {
      "type": "object",
      "description": "Approval workflow for the operation.",
      "properties": {
        "approval_required": {
          "type": "boolean"
        },
        "approval_status": {
          "type": "string",
          "enum": [
            "NOT_REQUIRED",
            "PENDING",
            "APPROVED",
            "REJECTED",
            "ESCALATED"
          ]
        },
        "approval_chain": {
          "type": "array",
          "description": "Sequential approval steps.",
          "items": {
            "type": "object",
            "properties": {
              "level": {
                "type": "integer"
              },
              "approver_id": {
                "type": "string"
              },
              "approver_role": {
                "type": "string"
              },
              "approval_action": {
                "type": "string",
                "enum": [
                  "PENDING",
                  "APPROVED",
                  "REJECTED",
                  "DELEGATED"
                ]
              },
              "approval_date": {
                "type": "string",
                "format": "date-time"
              },
              "approval_reason": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "financial_impact": {
      "type": "object",
      "description": "Financial implications of the operation.",
      "properties": {
        "has_financial_impact": {
          "type": "boolean"
        },
        "impact_type": {
          "type": "string",
          "enum": [
            "REVENUE_CHANGE",
            "COST_CHANGE",
            "ADJUSTMENT",
            "DISCOUNT",
            "REFUND",
            "SETTLEMENT",
            "WRITE_OFF",
            "ACCRUAL",
            "OTHER"
          ]
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "amount": {
          "type": "number",
          "description": "Monetary impact."
        },
        "affected_entities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entity_id": {
                "type": "string"
              },
              "entity_type": {
                "type": "string"
              },
              "impact_amount": {
                "type": "number"
              }
            }
          }
        },
        "reconciliation_status": {
          "type": "string",
          "enum": [
            "PENDING",
            "RECONCILED",
            "DISPUTE_PENDING"
          ]
        }
      }
    },
    "security_context": {
      "type": "object",
      "description": "Security and authentication context.",
      "properties": {
        "authentication_method": {
          "type": "string",
          "enum": [
            "PASSWORD",
            "MFA",
            "API_KEY",
            "OAUTH",
            "SAML",
            "SERVICE_ACCOUNT",
            "SYSTEM",
            "UNKNOWN"
          ]
        },
        "authentication_strength": {
          "type": "string",
          "enum": [
            "WEAK",
            "STANDARD",
            "STRONG",
            "VERY_STRONG"
          ]
        },
        "mfa_enabled": {
          "type": "boolean"
        },
        "permission_verification": {
          "type": "string",
          "enum": [
            "VERIFIED",
            "UNVERIFIED",
            "DENIED"
          ]
        },
        "data_classification": {
          "type": "string",
          "enum": [
            "PUBLIC",
            "INTERNAL",
            "CONFIDENTIAL",
            "RESTRICTED",
            "SECRET"
          ]
        }
      }
    },
    "correlation_id": {
      "type": "string",
      "description": "ID linking related audit records and operations together for end-to-end tracing."
    },
    "parent_audit_id": {
      "type": "string",
      "description": "Reference to parent operation if this is a sub-operation."
    },
    "related_audit_ids": {
      "type": "array",
      "description": "Other audit records related to this operation.",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "errors": {
      "type": "array",
      "description": "Errors or warnings encountered.",
      "items": {
        "type": "object",
        "properties": {
          "error_code": {
            "type": "string"
          },
          "error_message": {
            "type": "string"
          },
          "error_severity": {
            "type": "string",
            "enum": [
              "ERROR",
              "WARNING",
              "INFO"
            ]
          },
          "error_source": {
            "type": "string"
          }
        }
      }
    },
    "performance_metrics": {
      "type": "object",
      "description": "Performance metrics for the operation.",
      "properties": {
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "database_query_time_ms": {
          "type": "number",
          "minimum": 0
        },
        "api_call_count": {
          "type": "integer",
          "minimum": 0
        },
        "data_volume_bytes": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "retention_policy": {
      "type": "object",
      "description": "Data retention and lifecycle management.",
      "properties": {
        "retention_period_years": {
          "type": "integer",
          "minimum": 0
        },
        "retention_reason": {
          "type": "string",
          "enum": [
            "REGULATORY",
            "AUDIT_REQUIREMENT",
            "DISPUTE_RESOLUTION",
            "OPERATIONAL",
            "TAX_REQUIREMENT",
            "OTHER"
          ]
        },
        "can_be_deleted_at": {
          "type": "string",
          "format": "date-time"
        },
        "deletion_status": {
          "type": "string",
          "enum": [
            "RETAINED",
            "SCHEDULED_FOR_DELETION",
            "DELETED",
            "ANONYMIZED",
            "ARCHIVED"
          ]
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "description": "Extensible contextual attributes."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this audit record was created (immutable)."
    },
    "immutable": {
      "type": "boolean",
      "const": true,
      "description": "Audit records are immutable by design."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version."
    }
  },
  "examples": [
    {
      "audit_id": "aud_e4f7a2c1-b3d9-4e5f-a8c2-1d6e3f7a9b4c",
      "timestamp": "2025-02-19T14:32:15Z",
      "operation_type": "UPDATE",
      "operation_status": "SUCCESS",
      "actor": {
        "actor_type": "HUMAN",
        "actor_id": "user_001",
        "user_id": "user_001",
        "email": "manager@company.com",
        "ip_address": "192.0.2.1",
        "roles": [
          "FINANCE_MANAGER",
          "CONTRACT_MANAGER"
        ]
      },
      "target": {
        "entity_type": "CONTRACT",
        "entity_id": "ct_a7f4c9e2-d2f5-4b8e-c1d9",
        "entity_name": "Annual SaaS Subscription 2025",
        "entity_status_before": "ACTIVE",
        "entity_status_after": "AMENDED"
      },
      "changes": {
        "modified_fields": [
          {
            "field_name": "pricing_terms.base_amount",
            "old_value": 10000,
            "new_value": 11000,
            "change_type": "MODIFIED"
          },
          {
            "field_name": "pricing_terms.discount_percentage",
            "old_value": 5,
            "new_value": 7,
            "change_type": "MODIFIED"
          }
        ],
        "change_summary": "Price increase applied and discount adjusted per annual review"
      },
      "request_details": {
        "request_id": "req_20250219143215",
        "request_method": "API",
        "request_endpoint": "/contracts/ct_a7f4c9e2-d2f5-4b8e-c1d9",
        "response_status": 200,
        "response_time_ms": 125
      },
      "policies_evaluated": [
        {
          "policy_id": "pol_pricing_controls",
          "policy_name": "Pricing Change Controls",
          "enforcement_result": "ALLOWED"
        }
      ],
      "approval_chain": {
        "approval_required": true,
        "approval_status": "APPROVED",
        "approval_chain": [
          {
            "level": 1,
            "approver_id": "user_002",
            "approver_role": "DIRECTOR",
            "approval_action": "APPROVED",
            "approval_date": "2025-02-19T14:30:00Z"
          }
        ]
      },
      "financial_impact": {
        "has_financial_impact": true,
        "impact_type": "REVENUE_CHANGE",
        "currency": "USD",
        "amount": 1000
      },
      "correlation_id": "corr_20250219_14",
      "created_at": "2025-02-19T14:32:15Z"
    }
  ]
}
