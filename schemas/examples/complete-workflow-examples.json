  "workflow_3_outcome_based_pricing": {
    "title": "Outcome-Based Pricing: AI Customer Support Platform",
    "description": "Pricing based on successfully resolved support tickets",

    "step_1_create_outcome_pricing_rule": {
      "request": {
        "method": "POST",
        "url": "/ump/v1/pricing-rules",
        "body": {
          "rule_type": "OUTCOME_BASED",
          "name": "AI Support - Per Resolved Ticket",
          "service_id": "svc_ai_support_platform",
          "currency": "USD",
          "effective_from": "2026-03-01T00:00:00Z",
          "outcome_based_config": {
            "outcome_metric": "tickets_resolved_successfully",
            "measurement_method": "AI_SCORED",
            "pricing_model": "TIERED_ACHIEVEMENT",
            "performance_bands": [
              { "band_name": "Standard", "threshold_min": 0, "threshold_max": 90, "rate": 2.00, "premium_multiplier": 1.0 },
              { "band_name": "High Quality", "threshold_min": 90, "threshold_max": 95, "rate": 2.00, "premium_multiplier": 1.10 },
              { "band_name": "Exceptional", "threshold_min": 95, "threshold_max": 100, "rate": 2.00, "premium_multiplier": 1.20 }
            ],
            "base_fee": 500.00,
            "hybrid_transition": {
              "phases": [
                { "phase_name": "Onboarding", "start_month": 1, "end_month": 3, "base_fee_weight_pct": 70, "outcome_weight_pct": 30 },
                { "phase_name": "Transition", "start_month": 4, "end_month": 6, "base_fee_weight_pct": 50, "outcome_weight_pct": 50 },
                { "phase_name": "Full Outcome", "start_month": 7, "end_month": null, "base_fee_weight_pct": 30, "outcome_weight_pct": 70 }
              ]
            },
            "validation_config": {
              "validation_window_days": 7,
              "minimum_confidence_score": 0.90,
              "dispute_resolution_method": "MANUAL_REVIEW"
            }
          }
        }
      },
      "response": {
        "status": 201,
        "body": {
          "rule_id": "pr_outcome_support_001",
          "status": "PENDING_APPROVAL",
          "created_at": "2026-02-20T09:00:00Z"
        }
      }
    },

    "step_2_simulate_pricing": {
      "request": {
        "method": "POST",
        "url": "/ump/v1/pricing-rules/pr_outcome_support_001/simulate",
        "body": {
          "simulation_scenario": {
            "entity_id": "ent_customer_x",
            "period_months": 12,
            "projected_usage": {
              "monthly_tickets": 5000,
              "resolution_rate": 93,
              "average_confidence_score": 0.94
            }
          }
        }
      },
      "response": {
        "status": 200,
        "body": {
          "simulation_id": "sim_001",
          "monthly_projections": [
            { "month": 1, "base_component": 350.00, "outcome_component": 3300.00, "total": 3650.00, "note": "70/30 split phase" },
            { "month": 4, "base_component": 250.00, "outcome_component": 5500.00, "total": 5750.00, "note": "50/50 split phase" },
            { "month": 7, "base_component": 150.00, "outcome_component": 7700.00, "total": 7850.00, "note": "30/70 split phase" }
          ],
          "annual_projection": {
            "total_revenue": 72600.00,
            "vs_flat_rate": "+45%",
            "customer_cost_per_resolution": 1.21
          }
        }
      }
    }
  },

