  "workflow_2_multi_party_settlement": {
    "title": "Multi-Party Ecosystem Settlement: Telecom Bundle",
    "description": "Revenue settlement across telecom operator + banking partner + entertainment provider",

    "step_1_initiate_settlement": {
      "request": {
        "method": "POST",
        "url": "/ump/v1/settlements",
        "body": {
          "settlement_period": {
            "start": "2026-03-01T00:00:00Z",
            "end": "2026-03-31T23:59:59Z"
          },
          "allocation_method": "WATERFALL",
          "parties": [
            { "entity_id": "ent_telco_operator", "role": "ORCHESTRATOR" },
            { "entity_id": "ent_bank_partner", "role": "SERVICE_PROVIDER" },
            { "entity_id": "ent_streaming_provider", "role": "SERVICE_PROVIDER" }
          ],
          "waterfall_rules": [
            {
              "priority": 1,
              "recipient_entity_id": "ent_telco_operator",
              "allocation_type": "PERCENTAGE",
              "allocation_value": 50,
              "description": "Platform orchestration fee"
            },
            {
              "priority": 2,
              "recipient_entity_id": "ent_bank_partner",
              "allocation_type": "PERCENTAGE",
              "allocation_value": 30,
              "description": "Banking services revenue share"
            },
            {
              "priority": 3,
              "recipient_entity_id": "ent_streaming_provider",
              "allocation_type": "REMAINDER",
              "description": "Entertainment services remainder"
            }
          ],
          "source_invoices": ["inv_bundle_202603_001", "inv_bundle_202603_002"]
        }
      },
      "response": {
        "status": 201,
        "body": {
          "settlement_id": "stl_telco_202603",
          "status": "CALCULATED",
          "total_revenue": 485000.00,
          "settlement_amounts": [
            { "entity_id": "ent_telco_operator", "amount": 242500.00, "currency": "USD" },
            { "entity_id": "ent_bank_partner", "amount": 145500.00, "currency": "USD" },
            { "entity_id": "ent_streaming_provider", "amount": 97000.00, "currency": "USD" }
          ],
          "approval_chain": [
            { "approver_role": "finance_manager", "status": "PENDING" },
            { "approver_role": "cfo", "status": "PENDING" }
          ],
          "created_at": "2026-04-02T08:00:00Z"
        }
      }
    }
