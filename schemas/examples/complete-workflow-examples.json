    "step_3_create_tiered_pricing_rule": {
      "request": {
        "method": "POST",
        "url": "/ump/v1/pricing-rules",
        "body": {
          "rule_type": "TIERED",
          "name": "Analytics API - Tiered Pricing",
          "description": "Graduated tiered pricing for API calls with volume discounts",
          "service_id": "svc_analytics_api",
          "currency": "USD",
          "effective_from": "2026-03-01T00:00:00Z",
          "tiered_config": {
            "tier_mode": "GRADUATED",
            "metering_dimension": "api_calls",
            "tiers": [
              { "tier_start": 0, "tier_end": 10000, "rate": 0.01, "flat_fee": 0 },
              { "tier_start": 10001, "tier_end": 100000, "rate": 0.005, "flat_fee": 0 },
              { "tier_start": 100001, "tier_end": 1000000, "rate": 0.002, "flat_fee": 0 },
              { "tier_start": 1000001, "tier_end": null, "rate": 0.001, "flat_fee": 0 }
            ]
          },
          "discount_rules": [
            {
              "discount_type": "VOLUME_REBATE",
              "value": 5,
              "conditions": {
                "min_contract_term_months": 12,
                "eligible_segments": ["ENTERPRISE", "MID_MARKET"]
              },
              "stackable": false,
              "priority": 1
            }
          ],
          "approval_requirements": {
            "requires_approval": true,
            "approval_levels": [
              { "level": 1, "approver_role": "pricing_manager", "condition": "always" },
              { "level": 2, "approver_role": "cfo", "condition": "discount > 15%" }
            ]
          }
        }
      },
      "response": {
        "status": 201,
        "body": {
          "rule_id": "pr_tier_api_001",
          "rule_type": "TIERED",
          "status": "PENDING_APPROVAL",
          "approval_gate": "/ump/v1/approvals/apg_002",
          "created_at": "2026-02-17T10:10:00Z"
        }
      }
    },

